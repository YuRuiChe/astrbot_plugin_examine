{
  "foundation": {
    "description": "基本",
    "type": "object",
    "items": {
      "main_group_id": {
        "description": "主群群号",
        "type": "string",
        "hint": "大群",
        "default": ""
      },
      "examine_group_id": {
        "description": "审核群群号",
        "type": "string",
        "hint": "小群",
        "default": ""
      },
      "bot_name": {
        "description": "BOT名称",
        "type": "string",
        "hint": "你的 bot 在 Astrbot 上的名称",
        "default": ""
      }
    }
  },
  "group_entry_reminder": {
    "description": "入群提示",
    "type": "object",
    "items": {
      "reminder_text": {
        "description": "提示文本",
        "type": "text",
        "default": "欢迎！请向此 bot 私聊发送“开始答题”以开始考核"
      },
      "reminder_img": {
        "description": "提示图片",
        "hint": "推荐放置于 data/plugin_data/astrbot_plugin_examine 目录下，示例：data/plugin_data/astrbot_plugin_examine/img.jpg",
        "type": "string",
        "default": ""
      },
      "whether_at": {
        "description": "入群at",
        "type": "bool",
        "hint": "是否需要at发送入群提示，默认关闭",
        "default": false
      }
    }
  },
  "answer": {
    "description": "作答",
    "type": "object",
    "items": {
      "randomly_selected_questions": {
        "description": "随机抽题",
        "type": "bool",
        "hint": "是否需要进行随机抽题。若开启，则从题库中随机抽出题目；若关闭，则按照题目的先后顺序排列。默认关闭",
        "default": false
      },
      "stream_output_question": {
        "description": "逐题发送",
        "type": "bool",
        "hint": "作答时使题目一题一题发送，可避免漏答。默认关闭",
        "default": false
      },
      "finally_questions": {
        "description": "输出题数",
        "type": "int",
        "hint": "最终输出的题目数量",
        "default": 0
      },
      "total_score": {
        "description": "总分",
        "type": "int",
        "hint": "总分，将均分到每一道题，最好能被输出题数整除",
        "default": 100
      },
      "passing_line": {
        "description": "及格线",
        "type": "int",
        "hint": "只有成绩大与或等于及格线才会通过",
        "default": 60
      },
      "limited_time": {
        "description": "限时",
        "type": "int",
        "hint": "单位为秒（s），只有在限时内完成答题才会通过",
        "default": 100
      },
      "read_time": {
        "description": "阅读时间",
        "type": "int",
        "hint": "给予阅读考前须知的时间，单位为秒（s）",
        "default": 60
      }
    }
  },
  "card": {
    "description": "卡片",
    "type": "object",
    "hint": "完成答题后向群内发送的账号卡片",
    "items": {
      "send_user_answer": {
        "description": "发送作答答案",
        "type": "bool",
        "hint": "是否发送账号作答的答案，默认开启",
        "default": true
      }
    }
  },
  "question_bank": {
    "description": "题库",
    "type": "object",
    "hint": "请移动文件于 /data 文件夹下，并填写相应的文件路径",
    "items": {
      "question_bank_file": {
        "description": "题库文件（.json）",
        "type": "string",
        "hint": "推荐放置于 data/plugin_data/astrbot_plugin_examine 目录下，示例：data/plugin_data/astrbot_plugin_examine/question_bank.json",
        "default": ""
      }
    }
  }
}