{
  "main_group_id": {
    "description": "主群群号",
    "type": "string",
    "hint": "大群",
    "default": ""
  },
  "examine_group_id": {
    "description": "审核群群号",
    "type": "string",
    "hint": "小群",
    "default": ""
  },
  "bot_name": {
    "description": "BOT名称",
    "type": "string",
    "hint": "你的bot在astrbot平台上的名称",
    "default": ""
  },
  "group_entry_reminder": {
    "description": "入群提示",
    "type": "object",
    "items": {
      "reminder_text": {
        "description": "提示文本",
        "type": "text",
        "default": "欢迎！请向此bot私聊发送“开始答题”以开始考核"
      },
      "reminder_img": {
        "description": "提示图片",
        "hint": "填写提示图片的完整路径，默认为空",
        "type": "string",
        "default": ""
      },
      "whether_at": {
        "description": "入群at",
        "type": "bool",
        "hint": "是否需要at发送入群欢迎消息，默认关闭",
        "default": false
      }
    }
  },
  "answer": {
    "description": "作答",
    "type": "object",
    "items": {
      "total_number_of_questions": {
        "description": "总题数",
        "type": "int",
        "hint": "题库中有多少题",
        "default": 0
      },
      "finally_questions": {
        "description": "输出题数",
        "type": "int",
        "hint": "最终输出的题目数量",
        "default": 0
      },
      "total_score": {
        "description": "总分",
        "type": "int",
        "hint": "总分，将均分到每一道题，最好能被输出题数整除",
        "default": 100
      },
      "passing_line": {
        "description": "及格线",
        "type": "int",
        "hint": "只有成绩大与或等于及格线才会通过",
        "default": 60
      },
      "limited_time": {
        "description": "限时",
        "type": "int",
        "hint": "单位为秒（s），只有在限时内完成答题才会通过",
        "default": 100
      },
      "pre_exam_instructions": {
        "description": "考前须知",
        "type": "text",
        "hint": "开始考核前的须知",
        "default": "考前须知：\n请使用“作答”指令以答题，“确定”指令以结束答题\n示例：\n作答abcabcabcabc（前面一定要有“作答”二字！）\n总共有{self.finally_questions}道题，写多写少会提示\n请于{self.limited_time}秒内完成答题\n\n题目将于{self.read_time}秒后发送"
      },
      "read_time": {
        "description": "阅读时间",
        "type": "int",
        "hint": "给予新人阅读考前须知的时间，单位为秒（s）",
        "default": 60
      },
      "randomly_selected_questions": {
        "description": "随机抽题",
        "type": "bool",
        "hint": "是否需要进行随机抽题。若开启，则从题库中随机抽出题目；若关闭，则按照题目的先后顺序排列。默认关闭",
        "default": false
      }
    }
  },
  "card": {
    "description": "卡片",
    "type": "object",
    "hint": "完成答题后向群内发送的新人卡片",
    "items": {
      "send_user_answer": {
        "description": "发送作答答案",
        "type": "bool",
        "hint": "是否发送新人作答的答案，默认开启",
        "default": true
      }
    }
  },
  "question_bank": {
    "description": "题库",
    "type": "object",
    "hint": "请移动文件于data文件夹下，并填写相应的txt文件路径",
    "items": {
      "question": {
        "description": "问题",
        "type": "string",
        "hint": "示例：data/问题.txt",
        "default": ""
      },
      "option": {
        "description": "选项",
        "type": "string",
        "hint": "示例：data/选项.txt",
        "default": ""
      },
      "answer": {
        "description": "答案",
        "type": "string",
        "hint": "示例：data/答案.txt",
        "default": ""
      }
    }
  }
}