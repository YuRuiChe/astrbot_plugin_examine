{
  "main_group_id": {
    "description": "主群群号",
    "type": "string",
    "hint": "大群",
    "default": ""
  },
  "examine_group_id": {
    "description": "审核群群号",
    "type": "string",
    "hint": "小群",
    "default": ""
  },
  "group_entry_reminder": {
    "description": "入群提示",
    "type": "object",
    "items": {
      "reminder_text": {
        "description": "提示文本",
        "type": "text",
        "default": "欢迎！请私聊发送“开始答题”以开始测试"
      },
      "reminder_img": {
        "description": "提示图片",
        "hint": "填写提示图片的完整路径，默认为空",
        "type": "string",
        "default": ""
      },
      "whether_at": {
        "description": "是否需要at发送入群欢迎消息",
        "type": "bool",
        "hint": "是否需要at，默认关闭",
        "default": false
      }
    }
  },
  "answer": {
    "description": "作答",
    "type": "object",
    "items": {
      "total_number_of_questions": {
        "description": "总题数",
        "type": "int",
        "hint": "题库中有多少题",
        "default": 0
      },
      "total_score": {
        "description": "总分",
        "type": "int",
        "hint": "总分，将均分到每一道题，最好能被总题数整除",
        "default": 100
      },
      "passing_line": {
        "description": "及格线",
        "type": "int",
        "hint": "只有成绩大与或等于及格线才会通过",
        "default": 60
      },
      "limited_time": {
        "description": "限时",
        "type": "int",
        "hint": "单位为秒（s），只有在限时内完成答题才会通过",
        "default": 100
      },
      "randomly_selected_questions": {
        "description": "随机抽题",
        "type": "bool",
        "hint": "是否需要进行随机抽题，默认关闭",
        "default": false
      },
      "finally_questions": {
        "description": "目标题数",
        "type": "int",
        "hint": "如果开启了随机抽题，此数值为最终输出的题目数量",
        "default": 15
      }
    }
  },
  "question_bank": {
    "description": "题库",
    "type": "object",
    "items": {
      "question": {
        "description": "问题",
        "hint": "填写提示问题txt文件的完整路径",
        "type": "string",
        "default": ""
      },
      "option": {
        "description": "选项",
        "hint": "填写提示选项txt文件的完整路径",
        "type": "string",
        "default": ""
      },
      "answer": {
        "description": "答案",
        "hint": "填写提示答案txt文件的完整路径",
        "type": "string",
        "default": ""
      }
    }
  }
}